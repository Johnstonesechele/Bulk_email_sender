  <property name="styleSheet">
   <string notr="true">QMainWindow {
    background-color: #1a2332;
    color: #ffffff;
}

QTabWidget::pane {
    border: 1px solid #2d3748;
    background-color: #1a2332;
}

QTabBar::tab {
    background-color: #2d3748;
    color: #ffffff;
    padding: 8px 16px;
    margin-right: 2px;
    border-top-left-radius: 4px;
    border-top-right-radius: 4px;
}

QTabBar::tab:selected {
    background-color: #FFD700;
    color: #1a2332;
    font-weight: bold;
}

QTabBar::tab:hover {
    background-color: #4a5568;
}

QGroupBox {
    font-weight: bold;
    border: 2px solid #2d3748;
    border-radius: 6px;
    margin-top: 6px;
    padding-top: 10px;
    color: #ffffff;
}

QGroupBox::title {
    subcontrol-origin: margin;
    left: 10px;
    padding: 0 5px 0 5px;
    color: #FFD700;
}

QTableWidget {
    background-color: #2d3748;
    alternate-background-color: #4a5568;
    gridline-color: #1a2332;
    color: #ffffff;
    border: 1px solid #2d3748;
}

QTableWidget::item {
    padding: 4px;
}

QTableWidget::item:selected {
    background-color: #FFD700;
    color: #1a2332;
}

QHeaderView::section {
    background-color: #1a2332;
    color: #FFD700;
    padding: 4px;
    border: 1px solid #2d3748;
    font-weight: bold;
}

QLineEdit, QTextEdit {
    background-color: #2d3748;
    border: 1px solid #4a5568;
    border-radius: 4px;
    padding: 6px;
    color: #ffffff;
}

QLineEdit:focus, QTextEdit:focus {
    border: 2px solid #FFD700;
}

QPushButton {
    background-color: #2d3748;
    border: 1px solid #4a5568;
    border-radius: 4px;
    padding: 8px 16px;
    color: #ffffff;
    font-weight: bold;
}

QPushButton:hover {
    background-color: #4a5568;
    border-color: #FFD700;
}

QPushButton:pressed {
    background-color: #1a2332;
}

QPushButton:disabled {
    background-color: #1a2332;
    color: #718096;
}

QProgressBar {
    border: 1px solid #2d3748;
    border-radius: 4px;
    text-align: center;
    background-color: #2d3748;
    color: #ffffff;
}

QProgressBar::chunk {
    background-color: #FFD700;
    border-radius: 3px;
}

QStatusBar {
    background-color: #1a2332;
    color: #ffffff;
    border-top: 1px solid #2d3748;
}

QLabel {
    color: #ffffff;
}</string>
